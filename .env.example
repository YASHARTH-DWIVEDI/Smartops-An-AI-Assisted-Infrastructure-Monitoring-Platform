# ──────────────────────────────────────────────
#  SmartOps — Environment Configuration
#  Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite:///./smartops.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://smartops:secret@localhost:5432/smartops

# ── API Server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true

# ── Monitoring Agent ──────────────────────────
AGENT_API_URL=http://localhost:8000
AGENT_INTERVAL=10          # seconds between collections
SERVER_NAME=               # leave blank to use hostname

# ── Alert Thresholds ──────────────────────────
CPU_ALERT_THRESHOLD=90
MEMORY_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=85

# ── AI Engine ─────────────────────────────────
AI_PROVIDER=rule_based     # options: gemini | openai | rule_based
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email Alerts (optional) ───────────────────
ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL_FROM=smartops@yourcompany.com
ALERT_EMAIL_TO=oncall@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/smartops.log
