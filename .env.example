# ─────────────────────────────────────────────────────────────
# SmartOps — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────
SMARTOPS_ENV=development

# ── API Security ──────────────────────────────
# Set this to a strong random string to enable auth on all endpoints.
# Agents must send: Authorization: Bearer <this value>
# Leave empty to disable auth (dev/local mode only).
SMARTOPS_API_KEY=

# ── Database ─────────────────────────────────
# SQLite (default — no setup needed):
DATABASE_URL=sqlite:///./smartops.db

# PostgreSQL (production — use with docker-compose):
# DATABASE_URL=postgresql://smartops:smartops_secret@localhost:5432/smartops

# ── PostgreSQL (docker-compose only) ─────────
POSTGRES_DB=smartops
POSTGRES_USER=smartops
POSTGRES_PASSWORD=smartops_secret

# ── API Server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Agent ─────────────────────────────────────
AGENT_API_URL=http://localhost:8000
AGENT_INTERVAL=10
AGENT_SERVER_NAME=
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_DELAY=2
AGENT_BUFFER_FILE=/tmp/smartops_agent_buffer.ndjson
AGENT_BUFFER_MAX=500

# Log collection
LOG_COLLECT_INTERVAL=30
LOG_TAIL_LINES=50

# ── Alert Thresholds ─────────────────────────
ALERT_CPU_THRESHOLD=90
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=85
ALERT_COOLDOWN_MINUTES=15

# ── Email Alerts (optional) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── AI Engine ─────────────────────────────────
# Get your Gemini key at https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/smartops.log
